<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yanque.modules.rbac.mapper.SysRoleMapper">
    <resultMap id="RoleMap" type="com.yanque.modules.rbac.pojo.entity.SysRoleEntity">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="RoleColumns">id, role_code, role_name, description, status, created_at, updated_at</sql>

    <select id="selectById" resultMap="RoleMap">
        select <include refid="RoleColumns"/> from sys_role where id = #{id}
    </select>
    <select id="selectByRoleCode" resultMap="RoleMap">
        select <include refid="RoleColumns"/> from sys_role where role_code = #{roleCode}
    </select>
    <select id="selectExistingIds" resultType="java.lang.Long">
        select id from sys_role where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>
    <select id="selectList" resultMap="RoleMap">
        select <include refid="RoleColumns"/> from sys_role
        <where>
            <if test="roleCode != null and roleCode != ''">
                and role_code like concat('%', #{roleCode}, '%')
            </if>
            <if test="roleName != null and roleName != ''">
                and role_name like concat('%', #{roleName}, '%')
            </if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by id desc
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into sys_role (role_code, role_name, description, status, created_at, updated_at)
        values (#{roleCode}, #{roleName}, #{description}, #{status}, now(), now())
    </insert>
    <update id="updateById">
        update sys_role
        <set>
            <if test="roleCode != null">role_code = #{roleCode},</if>
            <if test="roleName != null">role_name = #{roleName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = now()
        </set>
        where id = #{id}
    </update>
    <delete id="deleteById">delete from sys_role where id = #{id}</delete>
</mapper>
