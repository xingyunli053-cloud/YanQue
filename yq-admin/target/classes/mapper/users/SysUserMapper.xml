<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yanque.modules.users.mapper.SysUserMapper">

    <resultMap id="SysUserMap" type="com.yanque.modules.users.pojo.entity.SysUserEntity">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="realName" column="real_name"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="unionId" column="union_id"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByUsername" resultMap="SysUserMap">
        select  id, username, password, nickname, real_name, phone, email, union_id, status, created_at, updated_at
            from sys_user where username = #{username}
    </select>

    <insert id="insert" parameterType="com.yanque.modules.users.pojo.entity.SysUserEntity"
            useGeneratedKeys="true" keyProperty="id">
        insert into sys_user
        (username, password, nickname, real_name, phone, email, union_id, status, created_at, updated_at)
        values
            (#{username}, #{password}, #{nickname}, #{realName}, #{phone}, #{email}, #{unionId},
             #{status}, now(), now())
    </insert>


</mapper>
